{
  "name": "sotto-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thin service over Canton's JSON Ledger API for the Sotto confidential-payout rail.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:rs256": "AUTH_MODE=rs256 tsx src/server.ts",
    "prove:rs256": "tsx scripts/prove-rs256.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
